def draw_board():
    for i in range(8):
        line = ""
        for j in range(8):
            if (i + j) % 2 == 0:
                line += "⬜"
            else:
                line += "⬛"
        print(line)

draw_board()

def is_valid_move(piece, start_pos, end_pos):
    # start_pos та end_pos - це координати (x, y)
    dx = abs(end_pos[0] - start_pos[0])
    dy = abs(end_pos[1] - start_pos[1])
    
    if piece == "Кінь":
        # Математичний патерн коня: (1,2) або (2,1)
        return (dx == 1 and dy == 2) or (dx == 2 and dy == 1)
    
    if piece == "Тура":
        # Один з показників зміщення має бути нульовим
        return dx == 0 or dy == 0

    return False

    if piece == "Слон":
        # Діагональний рух: зміщення по X дорівнює зміщенню по Y
        return dx == dy and dx > 0

    if piece == "Ферзь":
        # Комбінація Тури та Слона
        return (dx == dy or dx == 0 or dy == 0) and (dx > 0 or dy > 0)

    if piece == "Король":
        # Може ходити на 1 клітинку в будь-якому напрямку
        return dx <= 1 and dy <= 1 and (dx > 0 or dy > 0)

    if piece == "Пішак":
        # Спрощена логіка: тільки вперед (dy=1 або 2) без взяття фігур
        # Тут dx має бути 0 (йде прямо)
        return dx == 0 and (dy == 1 or dy == 2)
